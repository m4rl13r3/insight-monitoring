{
  "name": "insight-status",
  "version": "0.1.3",
  "description": "Self-hosted status page with HTTP, ICMP, TCP, DNS, and heartbeat monitoring.",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "vite build && node scripts/copy-vendor.mjs",
    "dev": "vite",
    "check": "tsc --noEmit && npm run check:js && npm run check:i18n",
    "check:js": "find public -name '*.js' -not -path 'public/assets/*' -print0 | xargs -0 -n1 node --check",
    "check:i18n": "node scripts/check-i18n.mjs"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.3.0",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  }
}
